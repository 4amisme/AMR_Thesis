# ==========================================
# 1. เตรียมข้อมูล
# ==========================================
# เลือกข้อมูลที่ต้องการ (ตัวอย่าง: กลุ่มยา mdr_id_numeric = 1)
df_plot_data <- df_final %>% filter(mdr_id_numeric == 1)
# ข้อมูลสำหรับ Heatmap (รายปี + รายเขต)
df_heatmap <- df_plot_data %>%
group_by(year, region_id) %>%
summarise(mean_percent = mean(percentage, na.rm = TRUE), .groups = "drop")
# ข้อมูลสำหรับ Line Chart (ภาพรวมประเทศ รายปี)
df_trend <- df_plot_data %>%
group_by(year) %>%
summarise(national_percent = mean(percentage, na.rm = TRUE), .groups = "drop")
# ข้อมูลสำหรับ Map (เลือกปีล่าสุด หรือปีที่สนใจมาแสดง)
target_year <- max(df_plot_data$year)
df_map_data <- df_heatmap %>% filter(year == target_year)
# โหลดแผนที่และนำข้อมูลไปเชื่อม
map_sf <- st_read("Regions_no_province_boundaries.json", quiet = TRUE)
map_sf$region_id <- as.numeric(map_sf$HealthRegion)
map_plot_data <- left_join(map_sf, df_map_data, by = "region_id")
# ==========================================
# 2. ตั้งค่าโทนสี (เขียว -> เหลือง -> ส้ม -> แดง แบบในรูป)
# ==========================================
# สร้างชุดสี Custom ให้เหมือนใน Dashboard ตัวอย่าง
narst_colors <- c("#1a9850", "#91cf60", "#d9ef8b", "#ffffbf", "#fee08b", "#fc8d59", "#d73027", "#7f0000")
# ==========================================
# 3. สร้างกราฟย่อย 3 ส่วน
# ==========================================
# กราฟ A: แผนที่ (ด้านซ้าย)
p_map <- ggplot(map_plot_data) +
geom_sf(aes(fill = mean_percent), color = "gray40", size = 0.3) +
geom_sf_text(aes(label = region_id), size = 3, color = "black") + # ใส่เลขเขต
scale_fill_gradientn(colors = narst_colors, limits = c(0, 100), name = "% AMR") +
theme_void() +
labs(title = paste("Spatial Distribution (Year", target_year, ")")) +
theme(
plot.title = element_text(face = "bold", hjust = 0.5, size = 13),
legend.position = "bottom",
legend.key.width = unit(1.5, "cm") # ขยายแถบสีให้กว้างแบบในรูป
)
# กราฟ B: Heatmap (บนขวา)
p_heat <- ggplot(df_heatmap, aes(x = factor(year), y = factor(region_id, levels = 13:1))) +
geom_tile(aes(fill = mean_percent), color = "white", size = 0.5) +
geom_text(aes(label = round(mean_percent, 1)), size = 3, color = "black") + # ตัวเลขในกรอบ
scale_fill_gradientn(colors = narst_colors, limits = c(0, 100), guide = "none") + # ซ่อน Legend ซ้ำซ้อน
theme_minimal() +
labs(x = NULL, y = "Health Region", title = "Spatial Aggregated Time Series (Heatmap)") +
theme(
plot.title = element_text(face = "bold", size = 11),
axis.text.x = element_blank(), # ซ่อนแกนปีไว้ (ไปโชว์ที่กราฟเส้นแทน)
panel.grid = element_blank()
)
# กราฟ C: Line Chart (ล่างขวา)
p_line <- ggplot(df_trend, aes(x = factor(year), y = national_percent, group = 1)) +
# ใส่พื้นที่แรเงาใต้กราฟเส้นบางๆ (เพื่อความสวยงามคล้ายรูป)
geom_area(fill = "gray80", alpha = 0.3) +
geom_line(color = "red", size = 1.2) +
geom_point(color = "darkred", size = 2.5) +
geom_text(aes(label = round(national_percent, 1)), vjust = -1.5, size = 3.5, fontface = "bold") +
theme_minimal() +
labs(x = "Year", y = "National AMR (%)", title = "Overall National Trend") +
coord_cartesian(ylim = c(0, 100)) + # ล็อกแกน Y ให้เป็น 0-100
theme(
plot.title = element_text(face = "bold", size = 11),
axis.text.x = element_text(angle = 45, hjust = 1)
)
# ==========================================
# 4. ประกอบร่างด้วย Patchwork!
# ==========================================
# ใช้เครื่องหมาย | (แบ่งซ้ายขวา) และ / (แบ่งบนล่าง)
final_dashboard <- (p_map | (p_heat / p_line)) +
plot_layout(widths = c(1, 1.3)) + # ให้ฝั่งกราฟ (ขวา) กว้างกว่าแผนที่นิดหน่อย
plot_annotation(
title = "Spatiotemporal plot of AMR percentage in Acinetobacter baumannii",
subtitle = "Choropleth map and spatial aggregated time series (Heatmap & Line chart)",
theme = theme(
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 12, color = "gray40")
)
)
# สั่งโชว์กราฟ
print(final_dashboard)
View(df_final)
View(df_final)
View(df_final)
View(df_combined)
View(df_final)
# ==========================================
# 3. ดึงค่าทำนายและกรองข้อมูลเตรียมพล็อต
# ==========================================
# ฟังก์ชันแก้ค่าติดลบ (Inverse Logit)
inv_logit <- function(x) { exp(x) / (1 + exp(x)) }
start_idx <- nrow(df_final) + 1
end_idx <- nrow(df_combined)
raw_pred <- pred_result$summary.fitted.values$mean[start_idx:end_idx]
scaled_pred <- ifelse(raw_pred < 0 | raw_pred > 1, inv_logit(raw_pred), raw_pred)
df_future$predicted_percent <- scaled_pred * 100
# ---------------------------------------------------------
# เพิ่มโค้ดส่วนนี้เพื่อบันทึกผลการทำนายลงไฟล์ CSV
# ---------------------------------------------------------
cat("กำลังบันทึกผลการทำนายลงไฟล์ 'predicted_aba_5years.csv' ...\n")
write.csv(df_future, "predicted_aba_5years.csv", row.names = FALSE)
cat("บันทึกเสร็จสมบูรณ์!\n")
# ---------------------------------------------------------
map_sf <- st_read("Regions_no_province_boundaries.json", quiet = TRUE)
map_sf$region_id <- as.numeric(map_sf$HealthRegion)
# ==========================================
# 3. ดึงค่าทำนายและกรองข้อมูลเตรียมพล็อต
# ==========================================
# ฟังก์ชันแก้ค่าติดลบ (Inverse Logit)
inv_logit <- function(x) { exp(x) / (1 + exp(x)) }
start_idx <- nrow(df_final) + 1
end_idx <- nrow(df_combined)
raw_pred <- pred_result$summary.fitted.values$mean[start_idx:end_idx]
scaled_pred <- ifelse(raw_pred < 0 | raw_pred > 1, inv_logit(raw_pred), raw_pred)
df_future$predicted_percent <- scaled_pred * 100
# ---------------------------------------------------------
# [เพิ่มใหม่] นำค่าพยากรณ์ทั้งหมด (อดีต + อนาคต) มาเซฟลงไฟล์
# ---------------------------------------------------------
# 1. ดึงค่าพยากรณ์รวมทั้งหมดใส่กลับเข้าไปในตารางใหญ่ (df_combined)
df_combined$fitted_mean <- pred_result$summary.fitted.values$mean
df_combined$predicted_percent <- ifelse(df_combined$fitted_mean < 0 | df_combined$fitted_mean > 1,
inv_logit(df_combined$fitted_mean),
df_combined$fitted_mean) * 100
# ไฟล์ที่ 2: ข้อมูลทั้งหมดรวมอดีตและผลทำนายอนาคต (สำหรับเก็บเป็น Master File)
write.csv(df_combined, "all_historical_and_predicted_results.csv", row.names = FALSE)
cat("บันทึกข้อมูลผลการทำนายลงไฟล์ CSV สำเร็จแล้ว!\n")
# ---------------------------------------------------------
