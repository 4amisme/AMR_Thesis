legend.key.width = unit(1.5, "cm") # ขยายแถบสีให้กว้างแบบในรูป
)
# กราฟ B: Heatmap (บนขวา)
p_heat <- ggplot(df_heatmap, aes(x = factor(year), y = factor(region_id, levels = 13:1))) +
geom_tile(aes(fill = mean_percent), color = "white", size = 0.5) +
geom_text(aes(label = round(mean_percent, 1)), size = 3, color = "black") + # ตัวเลขในกรอบ
scale_fill_gradientn(colors = narst_colors, limits = c(0, 100), guide = "none") + # ซ่อน Legend ซ้ำซ้อน
theme_minimal() +
labs(x = NULL, y = "Health Region", title = "Spatial Aggregated Time Series (Heatmap)") +
theme(
plot.title = element_text(face = "bold", size = 11),
axis.text.x = element_blank(), # ซ่อนแกนปีไว้ (ไปโชว์ที่กราฟเส้นแทน)
panel.grid = element_blank()
)
# กราฟ C: Line Chart (ล่างขวา)
p_line <- ggplot(df_trend, aes(x = factor(year), y = national_percent, group = 1)) +
# ใส่พื้นที่แรเงาใต้กราฟเส้นบางๆ (เพื่อความสวยงามคล้ายรูป)
geom_area(fill = "gray80", alpha = 0.3) +
