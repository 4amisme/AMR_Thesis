install.packages("INLA", repos=c(getOption("repos"), INLA="https://inla.r-inla-download.org/R/stable"), dep=TRUE)
library(INLA)
# 1. โหลดข้อมูลที่คุณเตรียมไว้จาก Python
df_final <- read.csv("aba_all_region_spatiotemporal_prepared.csv")
setwd("~/Documents/GitHub/AMR_Thesis/MDR/spatiotemperal")
# 1. โหลดข้อมูลที่คุณเตรียมไว้จาก Python
df_final <- read.csv("aba_all_region_spatiotemporal_prepared.csv")
# 2. กำหนดสมการ (Formula)
formula <- y_beta ~ 1 + sin_month + cos_month +
f(region_id, model = "besag", graph = "map.graph", scale.model = TRUE) +
f(time_id, model = "ar1") +
f(mdr_id_numeric, model = "iid")
# 3. รันโมเดล R-INLA (ใช้เวลาสักครู่)
cat("กำลังรันโมเดล R-INLA... โปรดรอสักครู่\n")
model_result <- inla(formula,
family = "beta",
data = df_final,
control.predictor = list(link = 1, compute = TRUE),
control.compute = list(dic = TRUE, waic = TRUE))
library(INLA)
library(dplyr)
library(sf)
library(ggplot2)
# ==========================================
# 1. สร้างข้อมูลอนาคต 5 ปี (ครอบคลุมทุกเขตและทุก Pattern)
# ==========================================
max_time_id <- max(df_final$time_id)
last_month <- 12 # สมมติเดือนล่าสุดคือธันวาคม
# สร้างตาราง Grid อนาคต (13 เขต x 60 เดือน x ทุกกลุ่มยาที่มี)
future_time_ids <- (max_time_id + 1):(max_time_id + 60)
regions <- 1:13
all_mdrs <- unique(df_final$mdr_id_numeric)
df_future <- expand.grid(time_id = future_time_ids,
region_id = regions,
mdr_id_numeric = all_mdrs)
df_future <- df_future %>%
mutate(
# สร้างเลขปีอนาคต (Year 1 ถึง Year 5)
future_year = ceiling((time_id - max_time_id) / 12),
# คำนวณรอบเดือน
month_numeric = ((last_month + (time_id - max_time_id) - 1) %% 12) + 1,
sin_month = sin(2 * pi * month_numeric / 12),
cos_month = cos(2 * pi * month_numeric / 12),
# ให้ค่าที่ต้องการทำนายเป็น NA
y_beta = NA
)
# นำข้อมูลอดีตและอนาคตมาต่อกัน
df_combined <- bind_rows(df_final, df_future)
# ==========================================
# 2. รันโมเดล R-INLA เพื่อทำนาย (Prediction)
# ==========================================
cat("กำลังรันโมเดลทำนาย... (ข้อมูลใหญ่ขึ้น อาจใช้เวลา 3-5 นาที)\n")
formula <- y_beta ~ 1 + sin_month + cos_month +
f(region_id, model = "besag", graph = "map.graph", scale.model = TRUE) +
f(time_id, model = "ar1") +
f(mdr_id_numeric, model = "iid")
pred_result <- inla(formula,
family = "beta",
data = df_combined,
control.predictor = list(link = 1, compute = TRUE))
# ==========================================
# 3. ดึงค่าทำนายและกรองข้อมูลเตรียมพล็อต
# ==========================================
# ฟังก์ชันแก้ค่าติดลบ (Inverse Logit)
inv_logit <- function(x) { exp(x) / (1 + exp(x)) }
start_idx <- nrow(df_final) + 1
end_idx <- nrow(df_combined)
raw_pred <- pred_result$summary.fitted.values$mean[start_idx:end_idx]
scaled_pred <- ifelse(raw_pred < 0 | raw_pred > 1, inv_logit(raw_pred), raw_pred)
df_future$predicted_percent <- scaled_pred * 100
map_sf <- st_read("Regions_no_province_boundaries.json", quiet = TRUE)
map_sf$region_id <- as.numeric(map_sf$HealthRegion)
# ==========================================
# 4. ฟังก์ชันสำหรับพล็อตแผนที่แยกตาม Pattern
# ==========================================
plot_prediction_map <- function(target_mdr_id) {
# 1. กรองข้อมูล
df_plot <- df_future %>%
filter(mdr_id_numeric == target_mdr_id,
(time_id - max_time_id) %% 12 == 0) %>%
mutate(Year_Label = paste("Future Year", future_year))
# 2. นำไปเชื่อมกับแผนที่
map_plot_data <- left_join(map_sf, df_plot, by = "region_id")
# --- ย้ายมาคำนวณตรงนี้ (ก่อนเข้า ggplot) ---
min_val <- min(df_plot$predicted_percent, na.rm = TRUE)
max_val <- max(df_plot$predicted_percent, na.rm = TRUE)
# ---------------------------------------
# 3. วาดแผนที่
p <- ggplot(map_plot_data) +
geom_sf(aes(fill = predicted_percent), color = "gray20", size = 0.1) +
scale_fill_viridis_c(option = "inferno",
name = "Resistance (%)",
limits = c(min_val, max_val)) + # ใช้ค่าที่คำนวณไว้
facet_wrap(~ Year_Label, nrow = 1) +
theme_void() +
labs(
title = paste("Prediction in 5 Years (Pattern ID:", target_mdr_id, ")"),
subtitle = "by Health Region (Adjusted Color Scale)"
) +
theme(
plot.title = element_text(size = 16, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 12, hjust = 0.5, margin = margin(b=15)),
legend.position = "bottom",
legend.key.width = unit(2, "cm")
)
print(p)
}
# ==========================================
# 5. สั่งวาดแผนที่! (เปลี่ยนเลข Pattern ที่สนใจตรงนี้ได้เลย)
# =========================================]
# ตัวอย่าง: ขอพล็อตดู Pattern ที่ 1
plot_prediction_map(target_mdr_id = 1)
plot_prediction_map(target_mdr_id = 2)
View(df_final)
View(map_sf)
View(pred_result)
View(df_final)
save.image("~/Documents/GitHub/AMR_Thesis/MDR/spatiotemperal/spatio.RData")
library(ggplot2)
library(dplyr)
# 1. เตรียมข้อมูลสำหรับพล็อต (รวมทั้งอดีตและอนาคต)
# ดึงค่าเฉลี่ย (Mean) และช่วงความเชื่อมั่น 95% (Lower/Upper)
plot_data <- df_combined %>%
mutate(
fit_mean = pred_result$summary.fitted.values$mean * 100,
fit_lower = pred_result$summary.fitted.values$`0.025quant` * 100,
fit_upper = pred_result$summary.fitted.values$`0.975quant` * 100,
# สร้างคอลัมน์ประเภทข้อมูลเพื่อแยกสี (Observed vs Predicted)
data_type = ifelse(time_id <= max_time_id, "Observed", "Predicted")
)
# 2. ฟังก์ชันพล็อตเส้นพยากรณ์แยกตามเขตสุขภาพ
plot_temporal_trend <- function(target_mdr_id) {
# กรองข้อมูลเฉพาะกลุ่มยาที่สนใจ
df_sub <- plot_data %>% filter(mdr_id_numeric == target_mdr_id)
ggplot(df_sub, aes(x = time_id, y = fit_mean)) +
# ส่วนที่ 1: ช่วงความเชื่อมั่น (พื้นที่สีจาง)
geom_ribbon(aes(ymin = fit_lower, ymax = fit_upper), fill = "blue", alpha = 0.1) +
# ส่วนที่ 2: เส้นพยากรณ์
geom_line(aes(color = data_type), size = 1) +
# ส่วนที่ 3: จุดข้อมูลจริงในอดีต (ถ้ามี)
geom_point(data = filter(df_sub, data_type == "Observed"),
aes(y = y_beta * 100), alpha = 0.4, size = 0.5) +
# แยกกราฟตามเขตสุขภาพ (Facet)
facet_wrap(~ region_id, ncol = 3, scales = "free_y") +
# ปรับแต่งความสวยงาม
scale_color_manual(values = c("Observed" = "black", "Predicted" = "blue")) +
theme_minimal() +
labs(
title = paste("Temporal Trends & Prediction for MDR Pattern:", target_mdr_id),
subtitle = "Black line: History | Blue line: 5-Year Prediction with 95% CI",
x = "Months (Timeline)",
y = "Resistance Percentage (%)"
) +
theme(
strip.background = element_rect(fill = "gray90"),
legend.position = "bottom",
plot.title = element_text(face = "bold", size = 14)
)
}
# 3. สั่งแสดงผล (เปลี่ยนเลข MDR_id ได้ตามต้องการ)
plot_temporal_trend(target_mdr_id = 1)
