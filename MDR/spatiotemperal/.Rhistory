library(ggplot2)
library(dplyr)
library(sf)
library(patchwork) # สำหรับประกอบกราฟ
# ==========================================
# 1. เตรียมข้อมูล
# ==========================================
# เลือกข้อมูลที่ต้องการ (ตัวอย่าง: กลุ่มยา mdr_id_numeric = 1)
df_plot_data <- df_final %>% filter(mdr_id_numeric == 1)
# ข้อมูลสำหรับ Heatmap (รายปี + รายเขต)
df_heatmap <- df_plot_data %>%
group_by(year, region_id) %>%
summarise(mean_percent = mean(percentage, na.rm = TRUE), .groups = "drop")
# ข้อมูลสำหรับ Line Chart (ภาพรวมประเทศ รายปี)
df_trend <- df_plot_data %>%
group_by(year) %>%
summarise(national_percent = mean(percentage, na.rm = TRUE), .groups = "drop")
# ข้อมูลสำหรับ Map (เลือกปีล่าสุด หรือปีที่สนใจมาแสดง)
target_year <- max(df_plot_data$year)
df_map_data <- df_heatmap %>% filter(year == target_year)
# โหลดแผนที่และนำข้อมูลไปเชื่อม
map_sf <- st_read("Regions_no_province_boundaries.json", quiet = TRUE)
map_sf$region_id <- as.numeric(map_sf$HealthRegion)
map_plot_data <- left_join(map_sf, df_map_data, by = "region_id")
# ==========================================
# 2. ตั้งค่าโทนสี (เขียว -> เหลือง -> ส้ม -> แดง แบบในรูป)
# ==========================================
# สร้างชุดสี Custom ให้เหมือนใน Dashboard ตัวอย่าง
