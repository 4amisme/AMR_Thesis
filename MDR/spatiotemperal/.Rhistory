geom_text(aes(label = round(national_percent, 1)), vjust = -1.5, size = 3.5, fontface = "bold") +
theme_minimal() +
labs(x = "Year", y = "National AMR (%)", title = "Overall National Trend") +
coord_cartesian(ylim = c(0, 100)) + # ล็อกแกน Y ให้เป็น 0-100
theme(
plot.title = element_text(face = "bold", size = 11),
axis.text.x = element_text(angle = 45
